<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BitMono.Host" Version="0.42.1" />
    <PackageReference Include="BitMono.Obfuscation" Version="0.42.1" />
    <PackageReference Include="BitMono.Protections" Version="0.42.1" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.6" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="BitMonoConfig\**\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
